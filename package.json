{
  "name": "findspot",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "typefloor": "node scripts/checkTypeFloor.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run typecheck && npm run typefloor",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "smoke": "playwright test tests/smoke.spec.ts",
    "regression": "playwright test tests/regression.spec.ts",
    "test:e2e": "playwright test",
    "test:all": "npm run typecheck && npm run test:e2e",
    "test:e2e:nix": "nix shell nixpkgs#chromium -c bash -lc 'export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=\"$(which chromium)\"; npm run test:e2e'",
    "test:all:nix": "npm run typecheck && npm run test:e2e:nix",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@geomatico/maplibre-cog-protocol": "^0.9.0",
    "@turf/turf": "^7.3.4",
    "@types/qrcode": "^1.5.6",
    "@types/turf": "^3.5.32",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "fflate": "^0.8.3",
    "h3-js": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "maplibre-gl": "^4.7.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.18",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6"
  }
}
